# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=FinTrack
APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://fintrack:fintrack_pass@localhost:5432/fintrack_db?schema=public

# ─────────────────────────────────────────────
# Redis
# LOCAL DEV:  REDIS_HOST=localhost
# DOCKER:     docker-compose overrides this to REDIS_HOST=redis automatically
# ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
REDIS_TLS=false

# ─────────────────────────────────────────────
# JWT  —  CHANGE THESE IN PRODUCTION (min 32 chars each)
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_xxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_xxxxxxxxxxx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# Email  —  dev: docker compose --profile dev up (MailHog)
# ─────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fintrack.io

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# ─────────────────────────────────────────────
# gRPC
# ─────────────────────────────────────────────
GRPC_AUTH_PORT=50051
GRPC_TRANSACTION_PORT=50052
GRPC_ANALYTICS_PORT=50053

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
